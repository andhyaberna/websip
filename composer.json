{
    "name": "websip/websip",
    "description": "WebSIP Application",
    "type": "project",
    "require": {
        "php": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/core/functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs app/",
        "format": "phpcbf app/"
    }
}
